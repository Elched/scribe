    <contact service="NOM DU SERVICE" local="LOCALISATION" tel="NUMÉRO"/>
    -->

    <contact service="STANDARD" local="Accueil principal" tel="0"/>
    <contact service="URGENCES — IOA" local="Accueil urgences" tel=""/>
    <contact service="SMUR" local="Salle SMUR" tel=""/>
    <contact service="REANIMATION" local="Salle de soins" tel=""/>
    <contact service="BLOC OPERATOIRE" local="Salle de régulation" tel=""/>
    <contact service="MATERNITE" local="Salle de soins" tel=""/>
    <contact service="PEDIATRIE" local="Salle de soins" tel=""/>
    <contact service="NEONATOLOGIE" local="Salle de soins" tel=""/>
    <contact service="CARDIOLOGIE" local="Salle de soins" tel=""/>
    <contact service="NEUROLOGIE" local="Salle de soins" tel=""/>
    <contact service="CADRE DE NUIT" local="Bureau cadre nuit" tel=""/>
    <contact service="PHARMACIE" local="Secrétariat" tel=""/>
    <contact service="IMAGERIE — SCANNER" local="" tel=""/>
    <contact service="LABORATOIRE" local="" tel=""/>
    <contact service="DIRECTION GENERALE" local="Secrétariat DG" tel=""/>
    <contact service="DSI INFORMATIQUE" local="Support DSI" tel=""/>
    <contact service="SECURITE" local="Loge sécurité" tel=""/>
    <contact service="SERVICES TECHNIQUES" local="Atelier" tel=""/>

    <!-- Ajoutez vos contacts -->

  </annuaire_normal>


  <!-- ════════════════════════════════════════════════════════
       7. ANNUAIRE DE SECOURS
       Numéros utilisables en cas de panne du système téléphonique
       (GSM personnels, fixes cuivre, astreintes)
       ════════════════════════════════════════════════════════ -->
  <annuaire_secours>

    <!--
    Format :
    <contact service="NOM" local="SITE OU INFO" tel="NUMÉRO" note="REMARQUE"/>
    -->

    <contact service="URGENCES — SECOURS" local="GSM de garde" tel="06 00 00 00 00" note="Disponible 24h/24"/>
    <contact service="REANIMATION — SECOURS" local="GSM de garde" tel="06 00 00 00 01" note=""/>
    <contact service="MATERNITE — SECOURS" local="GSM sage-femme" tel="06 00 00 00 02" note=""/>
    <contact service="BLOC — SECOURS" local="GSM IADE" tel="06 00 00 00 03" note=""/>
    <contact service="CADRE DE NUIT — SECOURS" local="GSM cadre" tel="06 00 00 00 04" note=""/>
    <contact service="DIRECTION — SECOURS" local="GSM DG/DGA" tel="06 00 00 00 05" note="Astreinte direction"/>
    <contact service="DSI — SECOURS" local="GSM DSI" tel="06 00 00 00 06" note="Astreinte informatique"/>
    <contact service="SAMU 15" local="Régulation médicale" tel="15" note="Urgences médicales"/>
    <contact service="POMPIERS 18" local="" tel="18" note=""/>
    <contact service="POLICE / GENDARMERIE 17" local="" tel="17" note=""/>
    <contact service="CERT SANTE" local="Signalement cyber" tel="cert-sante@esante.gouv.fr" note="Incidents cyber obligatoires"/>
    <contact service="ANSSI" local="Signalement national" tel="www.cybermalveillance.gouv.fr" note="Incidents critiques SI"/>

    <!-- Ajoutez vos numéros de secours -->

  </annuaire_secours>

  <!-- ════════════════════════════════════════════════════════
       8. CONFIGURATION IA (Intelligence Artificielle)
       Choisissez un fournisseur parmi :
         albert       → Albert AI (DINUM/gouvernement FR) — recommandé, souverain
         openai       → ChatGPT (GPT-4o, GPT-4o-mini...)
         anthropic    → Claude (claude-haiku-4-5-20251001, claude-sonnet-4-6...)
         gemini       → Google Gemini (gemini-2.0-flash, gemini-1.5-pro...)
         mistral      → Mistral AI (mistral-small-latest, mistral-large-latest...)
         ollama       → Modèle local Ollama (llama3, mistral, phi3... zéro donnée externe)
         openai_compat→ Tout serveur compatible OpenAI (LM Studio, vLLM, Jan...)

       Clé API : laissez vide si ollama ou openai_compat local sans authentification.
       URL base : laissez vide pour utiliser l'URL officielle du fournisseur choisi.
       ════════════════════════════════════════════════════════ -->
  <ia>
    <!-- Fournisseur actif — modifiez cette ligne pour changer de source IA -->
    <fournisseur>albert</fournisseur>

    <!-- Clé API du fournisseur (laissez vide pour Ollama local) -->
    <cle_api></cle_api>

    <!-- Modèle à utiliser (laissez vide pour le modèle par défaut du fournisseur)
         Exemples :
           albert     → mistralai/Ministral-3-8B-Instruct-2512
           openai     → gpt-4o-mini
           anthropic  → claude-haiku-4-5-20251001
           gemini     → gemini-2.0-flash
           mistral    → mistral-small-latest
           ollama     → llama3
    -->
    <modele></modele>

    <!-- URL de base (optionnel — uniquement pour ollama ou serveur local)
         Exemple Ollama : http://localhost:11434/v1/chat/completions
         Exemple LM Studio : http://localhost:1234/v1/chat/completions
    -->
    <url_base></url_base>
  </ia>

</scribe>
